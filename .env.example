# -----------------------------------------------------------------------
# SecureVault — Environment Variables
# -----------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# .env is listed in .gitignore and must NEVER be committed to version control.
# -----------------------------------------------------------------------

# REQUIRED — Flask session signing key.
# Generate a secure value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The old hardcoded key ("super_secret_vault_key_change_this_later") that
# was previously committed to the public repo should be treated as COMPROMISED.
FLASK_SECRET_KEY=

# OPTIONAL — Enable Werkzeug's interactive debugger for local development only.
# WARNING: Setting this to "true" in a deployed / public-facing environment
# allows REMOTE CODE EXECUTION via Werkzeug's browser-based debug console.
# Never set this to true in production.
FLASK_DEBUG=false
